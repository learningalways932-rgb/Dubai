def load_excel_file(uploaded_file):
    try:
        excel_data = pd.read_excel(uploaded_file, sheet_name=None, header=None)
        
        required_sheets = ['Category', 'Sub Category', 'Country Channel Category', 
                          'Disc Coupon', 'Channel', 'Country', 'INV']
        
        missing_sheets = [s for s in required_sheets if s not in excel_data]
        if missing_sheets:
            st.error(f"Missing required sheets: {', '.join(missing_sheets)}")
            return None
        
        processed_data = {}
        
        for sheet_name in required_sheets:
            if sheet_name == 'INV':
                processed_data[sheet_name] = excel_data[sheet_name]
            else:
                df_raw = excel_data[sheet_name]
                header_idx = None
                for idx in range(min(10, len(df_raw))):
                    row_vals = df_raw.iloc[idx].astype(str).str.lower().tolist()
                    if any(keyword in str(val).lower() for val in row_vals 
                           for keyword in ['category', 'sub', 'country', 'channel', 'disc', 'coupon', 
                                          'qty', 'amount', 'usd', 'total', 'balance']):
                        header_idx = idx
                        break
                
                if header_idx is not None:
                    df = pd.read_excel(uploaded_file, sheet_name=sheet_name, header=header_idx)
                else:
                    df = pd.read_excel(uploaded_file, sheet_name=sheet_name, header=0)
                
                df.columns = [str(col).strip() for col in df.columns]
                df = df.dropna(how='all')
                processed_data[sheet_name] = df
        
        return processed_data
        
    except Exception as e:
        st.error(f"Error loading Excel file: {str(e)}")
        return None

def calculate_kpis(excel_data):
    kpis = {}
    
    try:
        category_df = excel_data.get('Category', pd.DataFrame())
        if category_df.empty:
            st.error("Category sheet is empty or not found")
            return None
        
        category_df.columns = [str(col).strip() for col in category_df.columns]
        
        qty_col = None
        for col in category_df.columns:
            if 'qty' in col.lower() and 'balance' not in col.lower():
                qty_col = col
                break
        if not qty_col:
            for col in category_df.columns:
                if 'quantity' in col.lower() or 'sales qty' in col.lower():
                    qty_col = col
                    break
        
        kpis['Gross Sales Qty'] = pd.to_numeric(category_df[qty_col], errors='coerce').sum() if qty_col else 0
        
        amount_col = None
        for col in category_df.columns:
            if 'amount' in col.lower() and 'usd' in col.lower():
                amount_col = col
                break
        if not amount_col:
            for col in category_df.columns:
                if 'amount' in col.lower() or 'sales' in col.lower():
                    amount_col = col
                    break
        
        kpis['Gross Amount (USD)'] = pd.to_numeric(category_df[amount_col], errors='coerce').sum() if amount_col else 0
        
        inv_sheet = excel_data.get('INV', pd.DataFrame())
        if not inv_sheet.empty:
            try:
                total_balance = inv_sheet.iloc[0, 0]
                if pd.notna(total_balance):
                    try:
                        kpis['Balance Qty'] = float(total_balance)
                    except:
                        nums = re.findall(r'\d+\.?\d*', str(total_balance))
                        kpis['Balance Qty'] = float(nums[0]) if nums else 0
                else:
                    kpis['Balance Qty'] = 0
            except:
                kpis['Balance Qty'] = 0
        else:
            kpis['Balance Qty'] = 0
        
        kpis['Sales %'] = (kpis['Gross Sales Qty'] / kpis['Balance Qty']) * 100 if kpis['Balance Qty'] != 0 else 0
        
        report_date = "N/A"
        if not inv_sheet.empty and inv_sheet.shape[0] >= 2:
            try:
                date_value = inv_sheet.iloc[1, 0]
                if isinstance(date_value, pd.Timestamp):
                    report_date = date_value.strftime('%d-%m-%Y')
                elif pd.notna(date_value):
                    date_obj = pd.to_datetime(date_value, errors='coerce')
                    if not pd.isna(date_obj):
                        report_date = date_obj.strftime('%d-%m-%Y')
                    else:
                        date_str = str(date_value)
                        for pattern in [r'\d{2}/\d{2}/\d{4}', r'\d{2}-\d{2}-\d{4}', r'\d{4}/\d{2}/\d{2}', r'\d{4}-\d{2}-\d{2}']:
                            match = re.search(pattern, date_str)
                            if match:
                                date_obj = pd.to_datetime(match.group(), errors='coerce')
                                if not pd.isna(date_obj):
                                    report_date = date_obj.strftime('%d-%m-%Y')
                                    break
            except:
                pass
        
        kpis['Report Date'] = report_date
        return kpis
        
    except Exception as e:
        st.error(f"Error calculating KPIs: {str(e)}")
        return None

def display_kpi_card(title, value, is_percentage=False):
    if is_percentage:
        formatted_value = f"{value:.2f}%"
    elif isinstance(value, (int, np.integer)):
        formatted_value = f"{value:,.0f}"
    elif isinstance(value, (float, np.floating)):
        if 'Amount' in title or 'USD' in title:
            formatted_value = f"${value:,.2f}"
        else:
            formatted_value = f"{value:,.0f}"
    else:
        formatted_value = str(value)
    
    return f"""
    <div class="kpi-card">
        <div class="kpi-title">{title}</div>
        <div class="kpi-value">{formatted_value}</div>
    </div>
    """

def extract_numeric_value(value):
    if pd.isna(value) or value is None:
        return 0.0
    if isinstance(value, (int, float, np.number)):
        return float(value)
    cleaned = re.sub(r'[^\d\.\-]', '', str(value))
    try:
        return float(cleaned) if cleaned else 0.0
    except:
        return 0.0

def get_common_numeric_columns(dataframes):
    all_numeric_cols = []
    for df_name, df in dataframes.items():
        if df_name == 'INV':
            continue
        numeric_cols = []
        for col in df.columns:
            col_lower = str(col).lower()
            if col_lower in ['category', 'sub category', 'country', 'channel', 'disc coupon', 'coupon', 'disc', 'subcategory']:
                continue
            sample_values = df[col].dropna().head(10)
            if len(sample_values) > 0:
                try:
                    pd.to_numeric(sample_values, errors='coerce')
                    numeric_cols.append(col)
                except:
                    pass
        all_numeric_cols.append(set(numeric_cols))
    
    if all_numeric_cols:
        return sorted(list(set.intersection(*all_numeric_cols)))
    return []

def apply_sorting_to_dataframe(df, sort_column, sort_order):
    if df.empty or sort_column not in df.columns:
        return df
    df_copy = df.copy()
    temp_col = '_sort_temp'
    df_copy[temp_col] = df_copy[sort_column].apply(extract_numeric_value)
    ascending = (sort_order == "Ascending (Low to High)")
    df_copy = df_copy.sort_values(temp_col, ascending=ascending, na_position='last')
    df_copy = df_copy.drop(temp_col, axis=1)
    return df_copy

def format_dataframe(df, max_rows=None):
    """Format dataframe for display - no row limit when scroll is enabled"""
    if df.empty:
        return df
    
    # Only limit rows if max_rows is explicitly set
    if max_rows is not None:
        df = df.head(max_rows).copy()
    else:
        df = df.copy()
    
    for col in df.columns:
        col_lower = str(col).lower()
        if col_lower in ['category', 'sub category', 'country', 'channel', 'disc coupon', 'coupon', 'disc', 'subcategory']:
            continue
        if 'amount' in col_lower or 'usd' in col_lower or 'sales' in col_lower:
            df[col] = df[col].apply(lambda x: f"${extract_numeric_value(x):,.2f}")
        elif 'qty' in col_lower or 'balance' in col_lower or 'quantity' in col_lower:
            df[col] = df[col].apply(lambda x: f"{extract_numeric_value(x):,.0f}")
        elif '%' in col_lower or 'percent' in col_lower:
            df[col] = df[col].apply(lambda x: f"{extract_numeric_value(x):.2f}%")
    
    return df

